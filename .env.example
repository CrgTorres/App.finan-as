# =============================================================================
# Supabase (obrigatório em desenvolvimento e na Vercel)
# Dashboard do projeto → Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Opcional — URL canônica do site (útil para redirects e links absolutos)
# Em produção na Vercel, use algo como: https://seu-projeto.vercel.app
# =============================================================================
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Opcional — PDF de extrato protegido por senha (importação no dashboard)
# Tentada automaticamente antes de abrir o diálogo. Não versionar senhas reais.
# =============================================================================
# NEXT_PUBLIC_IMPORT_PDF_AUTO_PASSWORD=

# CPF só com dígitos (11) — gera candidatos de senha de PDF (ex.: 5 primeiros; Daycoval). Só em .env.local.
# NEXT_PUBLIC_USER_CPF_DIGITS_FOR_PDF=

# Legado (opcional): prefira cadastrar em /dashboard/perfil ou no registo (tabela user_profiles).
# NEXT_PUBLIC_USER_FULL_NAME=
# Após migração: execute supabase/migrations/add_user_profiles.sql no Supabase.
